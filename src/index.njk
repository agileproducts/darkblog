---
layout: layout.njk
title: Home
---

{% for post in collections.posts | reverse %}
  <article>
    <h2><a href="{{ post.url | url }}">{{ post.data.title }}</a></h2>
    <p class="post-meta">{{ post.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) }}</p>
    {% if post.data.excerpt %}
      <p>{{ post.data.excerpt }}</p>
    {% endif %}
  </article>
{% endfor %}
